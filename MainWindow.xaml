<ui:FluentWindow x:Class="HyperNote.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:HyperNote"
        xmlns:ctrl="clr-namespace:HyperNote.Controls"
        xmlns:services="clr-namespace:HyperNote.Services"
        Title="HyperNote"
        Height="780" Width="1200"
        Background="{DynamicResource App.Background}"
        Foreground="{DynamicResource App.Foreground}"
        AllowDrop="True" Drop="Window_Drop"
        Closing="Window_Closing"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.CommandBindings>
        <CommandBinding Command="New"    Executed="New_Executed"/>
        <CommandBinding Command="Open"   Executed="Open_Executed"/>
        <CommandBinding Command="Save"   Executed="Save_Executed"   CanExecute="Save_CanExecute"/>
        <CommandBinding Command="SaveAs" Executed="SaveAs_Executed" CanExecute="Save_CanExecute"/>
        <CommandBinding Command="Print"  Executed="Print_Executed"  CanExecute="Print_CanExecute"/>
        <CommandBinding Command="Close"  Executed="CloseTab_Executed"/>
        <CommandBinding Command="Find"    Executed="Find_Executed"    CanExecute="Find_CanExecute"/>
        <CommandBinding Command="Replace" Executed="Replace_Executed" CanExecute="Find_CanExecute"/>
        <CommandBinding Command="{x:Static local:MainWindow.FindNextCommand}"
                        Executed="FindNext_Executed" CanExecute="Find_CanExecute"/>
        <CommandBinding Command="{x:Static local:MainWindow.FindPreviousCommand}"
                        Executed="FindPrevious_Executed" CanExecute="Find_CanExecute"/>
        <CommandBinding Command="{x:Static local:MainWindow.SettingsCommand}"
                        Executed="Settings_Executed"/>
        <CommandBinding Command="{x:Static local:MainWindow.FormatDocumentCommand}"
                        Executed="FormatDocument_Executed" CanExecute="FormatDocument_CanExecute"/>
        <CommandBinding Command="{x:Static local:MainWindow.ToggleTerminalCommand}"
                        Executed="ToggleTerminal_Executed"/>
        <CommandBinding Command="{x:Static local:MainWindow.ToggleSidebarCommand}"
                        Executed="ToggleSidebar_Executed"/>
        <CommandBinding Command="{x:Static local:MainWindow.FuzzySearchCommand}"
                        Executed="FuzzySearch_Executed"/>
        <CommandBinding Command="{x:Static local:MainWindow.FindInFilesCommand}"
                        Executed="FindInFiles_Executed"/>
        <CommandBinding Command="{x:Static local:MainWindow.TransformTextCommand}"
                        Executed="TransformText_Executed" CanExecute="TransformText_CanExecute"/>
        <CommandBinding Command="{x:Static local:MainWindow.CommandPaletteCommand}"
                        Executed="CommandPalette_Executed"/>
        <CommandBinding Command="{x:Static local:MainWindow.GoToSymbolCommand}"
                        Executed="GoToSymbol_Executed" CanExecute="GoToSymbol_CanExecute"/>
        <CommandBinding Command="{x:Static local:MainWindow.ToggleBookmarkCommand}"
                        Executed="ToggleBookmark_Executed" CanExecute="ActiveEditor_CanExecute"/>
        <CommandBinding Command="{x:Static local:MainWindow.NextBookmarkCommand}"
                        Executed="NextBookmark_Executed" CanExecute="ActiveEditor_CanExecute"/>
        <CommandBinding Command="{x:Static local:MainWindow.PrevBookmarkCommand}"
                        Executed="PrevBookmark_Executed" CanExecute="ActiveEditor_CanExecute"/>
        <CommandBinding Command="{x:Static local:MainWindow.ClearBookmarksCommand}"
                        Executed="ClearBookmarks_Executed" CanExecute="ActiveEditor_CanExecute"/>


    </ui:FluentWindow.CommandBindings>

    <ui:FluentWindow.InputBindings>
        <KeyBinding Key="W" Modifiers="Control" Command="Close"/>
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="SaveAs"/>
        <KeyBinding Key="P" Modifiers="Control" Command="Print"/>
        <KeyBinding Key="V" Modifiers="Control+Shift"
                    Command="{x:Static local:MainWindow.TogglePreviewCommand}"/>
        <KeyBinding Key="F3" Command="{x:Static local:MainWindow.FindNextCommand}"/>
        <KeyBinding Key="F3" Modifiers="Shift"
                    Command="{x:Static local:MainWindow.FindPreviousCommand}"/>
        <KeyBinding Key="OemComma" Modifiers="Control"
                    Command="{x:Static local:MainWindow.SettingsCommand}"/>
        <KeyBinding Key="I" Modifiers="Control+Shift"
                    Command="{x:Static local:MainWindow.FormatDocumentCommand}"/>
        <KeyBinding Key="F" Modifiers="Alt+Shift"
                    Command="{x:Static local:MainWindow.FormatDocumentCommand}"/>
        <KeyBinding Key="P" Modifiers="Control+Shift"
                    Command="{x:Static local:MainWindow.CommandPaletteCommand}"/>
        <KeyBinding Key="O" Modifiers="Control+Shift"
                    Command="{x:Static local:MainWindow.GoToSymbolCommand}"/>
        <KeyBinding Key="OemTilde" Modifiers="Control"
                    Command="{x:Static local:MainWindow.ToggleTerminalCommand}"/>
        <KeyBinding Key="B" Modifiers="Control"
                    Command="{x:Static local:MainWindow.ToggleSidebarCommand}"/>
        <KeyBinding Key="P" Modifiers="Control"
                    Command="{x:Static local:MainWindow.FuzzySearchCommand}"/>
        <KeyBinding Key="G" Modifiers="Control"
                    Command="{x:Static local:MainWindow.GoToLineCommand}"/>
        <KeyBinding Key="F" Modifiers="Control+Shift"
                    Command="{x:Static local:MainWindow.FindInFilesCommand}"/>
        <!-- Custom menu command shortcuts -->
        <KeyBinding Key="N" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.NewWindowCommand}"/>
        <KeyBinding Key="F5" Command="{x:Static local:MainWindow.TimeDateCommand}"/>
        <!-- Bookmarks KeyBindings -->
        <KeyBinding Key="F2" Modifiers="Control" Command="{x:Static local:MainWindow.ToggleBookmarkCommand}"/>
        <KeyBinding Key="F2" Command="{x:Static local:MainWindow.NextBookmarkCommand}"/>
        <KeyBinding Key="F2" Modifiers="Shift" Command="{x:Static local:MainWindow.PrevBookmarkCommand}"/>
        <KeyBinding Key="F2" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.ClearBookmarksCommand}"/>


        <KeyBinding Key="OemPlus" Modifiers="Control" Command="{x:Static local:MainWindow.ZoomInCommand}"/>
        <KeyBinding Key="Add" Modifiers="Control" Command="{x:Static local:MainWindow.ZoomInCommand}"/>
        <KeyBinding Key="OemMinus" Modifiers="Control" Command="{x:Static local:MainWindow.ZoomOutCommand}"/>
        <KeyBinding Key="Subtract" Modifiers="Control" Command="{x:Static local:MainWindow.ZoomOutCommand}"/>
        <KeyBinding Key="D0" Modifiers="Control" Command="{x:Static local:MainWindow.ResetZoomCommand}"/>
        <KeyBinding Key="NumPad0" Modifiers="Control" Command="{x:Static local:MainWindow.ResetZoomCommand}"/>
    </ui:FluentWindow.InputBindings>

    <ui:FluentWindow.Resources>
        <!-- Sidebar animation storyboards -->
        <Storyboard x:Key="SidebarOpenStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="SidebarPanel"
                Storyboard.TargetProperty="Opacity"
                From="0" To="1"
                Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="SidebarCloseStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="SidebarPanel"
                Storyboard.TargetProperty="Opacity"
                From="1" To="0"
                Duration="0:0:0.12">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Search toggle button style -->
        <Style x:Key="SearchToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Foreground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Btn.BackgroundHover}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource App.Accent}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat-styled Toolbar button -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Foreground}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Btn.BackgroundHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Btn.BackgroundPress}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Vertical separator for toolbar groups -->
        <Style x:Key="ToolbarSeparatorStyle" TargetType="Border">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Background" Value="{DynamicResource App.Border}"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </ui:FluentWindow.Resources>

    <DockPanel>
        <ui:TitleBar x:Name="AppTitleBar" DockPanel.Dock="Top" Title="HyperNote"/>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  MENU BAR — Fluent Design with SymbolIcons on every item        -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Menu DockPanel.Dock="Top"
              Background="{DynamicResource App.ChromeBackground}"
              Foreground="{DynamicResource App.Foreground}"
              Padding="4,2"
              MinHeight="34"
              FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
              FontSize="13">

            <!-- File -->
            <MenuItem Header="_File">
                <MenuItem Header="_New" Command="New" InputGestureText="Ctrl+N">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="DocumentAdd24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="New _Window" Command="{x:Static local:MainWindow.NewWindowCommand}" InputGestureText="Ctrl+Shift+N">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="Document24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Open…" Command="Open" InputGestureText="Ctrl+O">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="FolderOpen24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Open _Folder…" Click="OpenFolder_Click">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="Folder24"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Save" Command="Save" InputGestureText="Ctrl+S">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="Save24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Save _As…" Command="SaveAs" InputGestureText="Ctrl+Shift+S">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="SaveCopy24"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Print…" Command="Print" InputGestureText="Ctrl+P">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="Print24"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem x:Name="RecentMenu" Header="Open _Recent">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="History24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Se_ssions">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="TabDesktop24"/></MenuItem.Icon>
                    <MenuItem Header="Save Session As…" Click="SaveSessionAs_Click">
                        <MenuItem.Icon><ui:SymbolIcon Symbol="Save24"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Open Session…" Click="OpenSession_Click">
                        <MenuItem.Icon><ui:SymbolIcon Symbol="FolderOpen24"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Delete Session…" Click="DeleteSession_Click">
                        <MenuItem.Icon><ui:SymbolIcon Symbol="Delete24"/></MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Close Tab" Command="Close" InputGestureText="Ctrl+W">

                    <MenuItem.Icon><ui:SymbolIcon Symbol="Dismiss24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="E_xit" Click="Exit_Click">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="Power24"/></MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <!-- Edit -->
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Command="Undo" InputGestureText="Ctrl+Z">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="ArrowUndo24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Redo" Command="Redo" InputGestureText="Ctrl+Y">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="ArrowRedo24"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Cu_t" Command="Cut" InputGestureText="Ctrl+X">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="Cut24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Copy" Command="Copy" InputGestureText="Ctrl+C">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="Copy24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Paste" Command="Paste" InputGestureText="Ctrl+V">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="ClipboardPaste24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Delete" Command="Delete" InputGestureText="Del">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="Delete24"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Find…" Command="Find" InputGestureText="Ctrl+F">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="Search24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Replace…" Command="Replace" InputGestureText="Ctrl+H">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="ArrowSwap24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Find in _Files…"
                          Command="{x:Static local:MainWindow.FindInFilesCommand}"
                          InputGestureText="Ctrl+Shift+F">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="SearchSquare24"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Find _Next"
                          Command="{x:Static local:MainWindow.FindNextCommand}"
                          InputGestureText="F3">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="ArrowDown24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Find _Previous"
                          Command="{x:Static local:MainWindow.FindPreviousCommand}"
                          InputGestureText="Shift+F3">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="ArrowUp24"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Go to _File…"
                          Command="{x:Static local:MainWindow.FuzzySearchCommand}"
                          InputGestureText="Ctrl+P">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="DocumentSearch24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Go to _Line…"
                          Command="{x:Static local:MainWindow.GoToLineCommand}"
                          InputGestureText="Ctrl+G">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="ArrowRight24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Go to _Symbol…"
                          Command="{x:Static local:MainWindow.GoToSymbolCommand}"
                          InputGestureText="Ctrl+Shift+O">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="Code24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Command _Palette…"
                          Command="{x:Static local:MainWindow.CommandPaletteCommand}"
                          InputGestureText="Ctrl+Shift+P">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="KeyCommand24"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Select _All" Command="SelectAll" InputGestureText="Ctrl+A">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="SelectAllOn24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Time/_Date"
                          Command="{x:Static local:MainWindow.TimeDateCommand}"
                          InputGestureText="F5">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="Clock24"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Format Document"
                          Command="{x:Static local:MainWindow.FormatDocumentCommand}"
                          InputGestureText="Ctrl+Shift+I">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="TextSortAscending24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Transform _Text">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="TextClearFormatting24"/></MenuItem.Icon>
                    <MenuItem Header="Convert _Case">
                        <MenuItem.Icon><ui:SymbolIcon Symbol="TextChangeCase24"/></MenuItem.Icon>
                        <MenuItem Header="UPPERCASE" Command="{x:Static local:MainWindow.TransformTextCommand}" CommandParameter="Uppercase"/>
                        <MenuItem Header="lowercase" Command="{x:Static local:MainWindow.TransformTextCommand}" CommandParameter="Lowercase"/>
                        <MenuItem Header="Title Case" Command="{x:Static local:MainWindow.TransformTextCommand}" CommandParameter="TitleCase"/>
                        <MenuItem Header="Sentence Case" Command="{x:Static local:MainWindow.TransformTextCommand}" CommandParameter="SentenceCase"/>
                        <Separator/>
                        <MenuItem Header="camelCase" Command="{x:Static local:MainWindow.TransformTextCommand}" CommandParameter="CamelCase"/>
                        <MenuItem Header="snake_case" Command="{x:Static local:MainWindow.TransformTextCommand}" CommandParameter="SnakeCase"/>
                    </MenuItem>
                    <MenuItem Header="_Sort Lines">
                        <MenuItem.Icon><ui:SymbolIcon Symbol="ArrowSortDownLines24"/></MenuItem.Icon>
                        <MenuItem Header="A-Z (Ascending)"   Command="{x:Static local:MainWindow.TransformTextCommand}" CommandParameter="SortAsc"/>
                        <MenuItem Header="Z-A (Descending)"  Command="{x:Static local:MainWindow.TransformTextCommand}" CommandParameter="SortDesc"/>
                        <MenuItem Header="A-Z (Ignore Case)" Command="{x:Static local:MainWindow.TransformTextCommand}" CommandParameter="SortAscIgnoreCase"/>
                        <MenuItem Header="Z-A (Ignore Case)" Command="{x:Static local:MainWindow.TransformTextCommand}" CommandParameter="SortDescIgnoreCase"/>
                    </MenuItem>
                    <MenuItem Header="Remove _Duplicate Lines" Command="{x:Static local:MainWindow.TransformTextCommand}" CommandParameter="RemoveDuplicates"/>
                    <MenuItem Header="_Trim Whitespace">
                        <MenuItem Header="Trim Leading"  Command="{x:Static local:MainWindow.TransformTextCommand}" CommandParameter="TrimLeading"/>
                        <MenuItem Header="Trim Trailing" Command="{x:Static local:MainWindow.TransformTextCommand}" CommandParameter="TrimTrailing"/>
                        <MenuItem Header="Trim Both"     Command="{x:Static local:MainWindow.TransformTextCommand}" CommandParameter="TrimBoth"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="URL Encode"    Command="{x:Static local:MainWindow.TransformTextCommand}" CommandParameter="UrlEncode"/>
                    <MenuItem Header="URL Decode"    Command="{x:Static local:MainWindow.TransformTextCommand}" CommandParameter="UrlDecode"/>
                    <MenuItem Header="Base64 Encode" Command="{x:Static local:MainWindow.TransformTextCommand}" CommandParameter="Base64Encode"/>
                    <MenuItem Header="Base64 Decode" Command="{x:Static local:MainWindow.TransformTextCommand}" CommandParameter="Base64Decode"/>
                    <MenuItem Header="HTML Encode"   Command="{x:Static local:MainWindow.TransformTextCommand}" CommandParameter="HtmlEncode"/>
                    <MenuItem Header="HTML Decode"   Command="{x:Static local:MainWindow.TransformTextCommand}" CommandParameter="HtmlDecode"/>
                    <Separator/>
                    <MenuItem Header="Minify JSON/XML" Command="{x:Static local:MainWindow.TransformTextCommand}" CommandParameter="MinifyJsonXml"/>
                </MenuItem>
                <Separator/>

            </MenuItem>

            <!-- View -->
            <MenuItem Header="_View">
                <MenuItem x:Name="DarkThemeMenu" Header="_Dark Theme" IsCheckable="True"
                          Click="ToggleTheme_Click">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="WeatherMoon24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Toggle _Preview" Click="TogglePreview_Click"
                          InputGestureText="Ctrl+Shift+V">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="Eye24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Toggle _Terminal"
                          Command="{x:Static local:MainWindow.ToggleTerminalCommand}"
                          InputGestureText="Ctrl+`">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="Prompt24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Toggle _Sidebar"
                          Command="{x:Static local:MainWindow.ToggleSidebarCommand}"
                          InputGestureText="Ctrl+B">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="PanelLeft24"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Zoom">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="ZoomIn24"/></MenuItem.Icon>
                    <MenuItem Header="Zoom _In" Command="{x:Static local:MainWindow.ZoomInCommand}" InputGestureText="Ctrl+Plus">
                        <MenuItem.Icon><ui:SymbolIcon Symbol="ZoomIn24"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Zoom _Out" Command="{x:Static local:MainWindow.ZoomOutCommand}" InputGestureText="Ctrl+Minus">
                        <MenuItem.Icon><ui:SymbolIcon Symbol="ZoomOut24"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="_Reset Zoom" Command="{x:Static local:MainWindow.ResetZoomCommand}" InputGestureText="Ctrl+0">
                        <MenuItem.Icon><ui:SymbolIcon Symbol="ZoomIn24"/></MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <Separator/>
                <MenuItem x:Name="WordWrapMenu" Header="Word _Wrap" IsCheckable="True" Click="ToggleWordWrap_Click">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="TextWrap24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="LineNumbersMenu" Header="Line _Numbers" IsCheckable="True" Click="ToggleLineNumbers_Click">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="TextNumberListLtr24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="MinimapMenu" Header="Show _Minimap" IsCheckable="True" Click="ToggleMinimap_Click">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="Map24"/></MenuItem.Icon>
                </MenuItem>

                <MenuItem x:Name="WhitespaceMenu" Header="Show _Whitespace" IsCheckable="True" Click="ToggleWhitespace_Click">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="Eye24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="HighlightLineMenu" Header="Highlight _Current Line" IsCheckable="True" Click="ToggleHighlightLine_Click">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="Highlight24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="StatusBarMenu" Header="Status _Bar" IsCheckable="True" Click="ToggleStatusBar_Click">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="Status24"/></MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <!-- Tools -->
            <MenuItem Header="_Tools">
                <MenuItem Header="_Settings…"
                          Command="{x:Static local:MainWindow.SettingsCommand}"
                          InputGestureText="Ctrl+,">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="Settings24"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Compare _Files…" Click="CompareFiles_Click">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="BranchFork24"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Compute _Hash…" Click="ComputeHash_Click">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="ShieldKeyhole24"/></MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <!-- Help -->
            <MenuItem Header="_Help">
                <MenuItem Header="View _Help" Click="Help_Click">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="QuestionCircle24"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_About HyperNote" Click="About_Click">
                    <MenuItem.Icon><ui:SymbolIcon Symbol="Info24"/></MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  APPLICATION TOOLBAR — Quick access to key operations            -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" 
                Background="{DynamicResource App.ChromeBackground}"
                BorderBrush="{DynamicResource App.Border}"
                BorderThickness="0,0,0,1"
                Padding="8,5">
            <StackPanel Orientation="Horizontal">
                <!-- File Group -->
                <Button Style="{StaticResource ToolbarButtonStyle}" Command="New" ToolTip="New File (Ctrl+N)">
                    <ui:SymbolIcon Symbol="DocumentAdd24"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" Command="{x:Static local:MainWindow.NewWindowCommand}" ToolTip="New Window (Ctrl+Shift+N)">
                    <ui:SymbolIcon Symbol="Document24"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" Command="Open" ToolTip="Open File (Ctrl+O)">
                    <ui:SymbolIcon Symbol="FolderOpen24"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" Command="Save" ToolTip="Save File (Ctrl+S)">
                    <ui:SymbolIcon Symbol="Save24"/>
                </Button>

                <Border Style="{StaticResource ToolbarSeparatorStyle}"/>

                <!-- Edit & Clipboard Group -->
                <Button Style="{StaticResource ToolbarButtonStyle}" Command="Undo" ToolTip="Undo (Ctrl+Z)">
                    <ui:SymbolIcon Symbol="ArrowUndo24"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" Command="Redo" ToolTip="Redo (Ctrl+Y)">
                    <ui:SymbolIcon Symbol="ArrowRedo24"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" Command="Cut" ToolTip="Cut (Ctrl+X)">
                    <ui:SymbolIcon Symbol="Cut24"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" Command="Copy" ToolTip="Copy (Ctrl+C)">
                    <ui:SymbolIcon Symbol="Copy24"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" Command="Paste" ToolTip="Paste (Ctrl+V)">
                    <ui:SymbolIcon Symbol="ClipboardPaste24"/>
                </Button>

                <Border Style="{StaticResource ToolbarSeparatorStyle}"/>

                <!-- Text Format & Insert -->
                <Button Style="{StaticResource ToolbarButtonStyle}" 
                        Command="{x:Static local:MainWindow.FormatDocumentCommand}" 
                        ToolTip="Format Document (Ctrl+Shift+I)">
                    <ui:SymbolIcon Symbol="TextSortAscending24"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" 
                        Command="{x:Static local:MainWindow.TimeDateCommand}" 
                        ToolTip="Insert Time/Date (F5)">
                    <ui:SymbolIcon Symbol="Clock24"/>
                </Button>

                <Border Style="{StaticResource ToolbarSeparatorStyle}"/>

                <!-- Navigation & Search Group -->
                <Button Style="{StaticResource ToolbarButtonStyle}" Command="Find" ToolTip="Find (Ctrl+F)">
                    <ui:SymbolIcon Symbol="Search24"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" Command="Replace" ToolTip="Replace (Ctrl+H)">
                    <ui:SymbolIcon Symbol="ArrowSwap24"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" 
                        Command="{x:Static local:MainWindow.FuzzySearchCommand}" 
                        ToolTip="Go to File (Ctrl+P)">
                    <ui:SymbolIcon Symbol="DocumentSearch24"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" 
                        Command="{x:Static local:MainWindow.CommandPaletteCommand}" 
                        ToolTip="Command Palette (Ctrl+Shift+P)">
                    <ui:SymbolIcon Symbol="KeyCommand24"/>
                </Button>

                <Border Style="{StaticResource ToolbarSeparatorStyle}"/>

                <!-- View Group (Zoom & Panes) -->
                <Button Style="{StaticResource ToolbarButtonStyle}" 
                        Command="{x:Static local:MainWindow.ToggleSidebarCommand}" 
                        ToolTip="Toggle Sidebar (Ctrl+B)">
                    <ui:SymbolIcon Symbol="PanelLeft24"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" 
                        Command="{x:Static local:MainWindow.TogglePreviewCommand}" 
                        ToolTip="Toggle Preview (Ctrl+Shift+V)">
                    <ui:SymbolIcon Symbol="Eye24"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" 
                        Command="{x:Static local:MainWindow.ToggleTerminalCommand}" 
                        ToolTip="Toggle Terminal (Ctrl+`)">
                    <ui:SymbolIcon Symbol="Prompt24"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" 
                        Command="{x:Static local:MainWindow.ZoomInCommand}" 
                        ToolTip="Zoom In (Ctrl+Plus)">
                    <ui:SymbolIcon Symbol="ZoomIn24"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}" 
                        Command="{x:Static local:MainWindow.ZoomOutCommand}" 
                        ToolTip="Zoom Out (Ctrl+Minus)">
                    <ui:SymbolIcon Symbol="ZoomOut24"/>
                </Button>

                <Border Style="{StaticResource ToolbarSeparatorStyle}"/>

                <!-- Compute Hash -->
                <Button Style="{StaticResource ToolbarButtonStyle}" 
                        Click="ComputeHash_Click" 
                        ToolTip="Compute Hash...">
                    <ui:SymbolIcon Symbol="ShieldKeyhole24"/>
                </Button>

                <!-- Settings -->
                <Button Style="{StaticResource ToolbarButtonStyle}" 
                        Command="{x:Static local:MainWindow.SettingsCommand}" 
                        ToolTip="Settings (Ctrl+,)">
                    <ui:SymbolIcon Symbol="Settings24"/>
                </Button>
            </StackPanel>
        </Border>

        <Border x:Name="RecoveryBanner" DockPanel.Dock="Top" Background="{DynamicResource Banner.Background}" BorderBrush="{DynamicResource App.Border}" BorderThickness="0,0,0,1" Padding="12,8" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Warning24" Foreground="{DynamicResource Banner.Foreground}" Margin="0,0,8,0"/>
                    <TextBlock Text="HyperNote closed unexpectedly. Do you want to recover unsaved files?" Foreground="{DynamicResource Banner.Foreground}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Recover Files" Click="RecoverOrphans_Click" Padding="12,4" Margin="0,0,8,0" Cursor="Hand"/>
                    <Button Content="Discard" Click="DiscardOrphans_Click" Padding="12,4" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>


        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  STATUS BAR                                                      -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <StatusBar x:Name="AppStatusBar" DockPanel.Dock="Bottom"
                   Background="{DynamicResource App.ChromeBackground}"
                   Foreground="{DynamicResource App.Foreground}"
                   BorderBrush="{DynamicResource App.Border}"
                   BorderThickness="0,1,0,0"
                   Padding="4,3"
                   FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                   FontSize="12">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <!-- Left: status message -->
            <StatusBarItem Grid.Column="0">
                <TextBlock x:Name="StatusText" Text="Ready" Margin="6,0,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </StatusBarItem>

            <!-- Right: all indicators -->
            <StatusBarItem Grid.Column="1" HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                    <!-- Text statistics -->
                    <TextBlock x:Name="TextStatsText" Text="" Margin="16,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Editor.LineNumbers}"/>
                    <Separator Width="1" Height="14" Background="{DynamicResource App.Border}" VerticalAlignment="Center"/>

                    <!-- Caret position -->
                    <TextBlock x:Name="CaretStatusText" Text="" Margin="16,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Editor.LineNumbers}"/>
                    <Separator Width="1" Height="14" Background="{DynamicResource App.Border}" VerticalAlignment="Center"/>

                    <!-- File size & encoding (clickable) -->
                    <TextBlock x:Name="FileInfoText" Text="" Margin="16,0"
                               VerticalAlignment="Center"
                               Cursor="Hand"
                               ToolTip="File size and encoding. Click to change encoding"
                               MouseDown="FileInfoText_MouseDown"
                               Foreground="{DynamicResource Editor.LineNumbers}"/>
                    <Separator Width="1" Height="14" Background="{DynamicResource App.Border}" VerticalAlignment="Center"/>

                    <!-- Language selector -->
                    <Button x:Name="LanguageSelectorBtn" Click="LanguageSelector_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource App.Foreground}"
                            Padding="10,0" Height="22" VerticalAlignment="Center"
                            Cursor="Hand" ToolTip="Change Syntax Highlighting"
                            FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                            FontSize="12">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Code24" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="LanguageSelectorText" Text="Plain Text" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="Transparent"
                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Btn.BackgroundHover}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Separator Width="1" Height="14" Background="{DynamicResource App.Border}" VerticalAlignment="Center"/>

                    <!-- Zoom -->
                    <StackPanel Orientation="Horizontal" Margin="12,0,6,0" VerticalAlignment="Center"
                                Cursor="Hand" ToolTip="Zoom level (Ctrl+Wheel to zoom. Double-click to reset)">
                        <StackPanel.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" Command="{x:Null}"/>
                        </StackPanel.InputBindings>
                        <ui:SymbolIcon Symbol="ZoomIn24" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource Editor.LineNumbers}"/>
                        <TextBlock x:Name="ZoomStatusText" Text="100%"
                                   Foreground="{DynamicResource Editor.LineNumbers}"
                                   MouseDown="ZoomStatus_MouseDown"/>
                    </StackPanel>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  MAIN CONTENT AREA                                              -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="0"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─────────────────────────────────────────────────────────── -->
            <!--  SIDEBAR — Fluent NavigationView pattern                    -->
            <!-- ─────────────────────────────────────────────────────────── -->
            <Grid x:Name="SidebarPanel" Grid.Column="0"
                  Background="{DynamicResource App.ChromeBackground}"
                  Visibility="Collapsed" Opacity="0">
                <DockPanel>
                    <!-- Sidebar header with NavigationView-style icon tabs -->
                    <Border DockPanel.Dock="Top"
                            BorderBrush="{DynamicResource App.Border}"
                            BorderThickness="0,0,0,1"
                            Padding="6,4">
                        <DockPanel LastChildFill="True">
                            <!-- Close sidebar button -->
                            <Button DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Width="26" Height="26" Padding="0" Margin="0"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource App.Foreground}"
                                    Cursor="Hand" ToolTip="Close Sidebar (Ctrl+B)"
                                    Click="CloseSidebar_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="5">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Btn.BackgroundHover}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Btn.BackgroundPress}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <ui:SymbolIcon Symbol="Dismiss24" FontSize="12"/>
                            </Button>

                            <!-- NavigationView tabs -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Explorer tab button -->
                                <Button x:Name="SidebarTabExplorer"
                                        Click="SidebarTabExplorer_Click"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource App.Accent}"
                                        FontWeight="SemiBold" FontSize="11"
                                        FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                                        Margin="0,0,4,0" Padding="6,4"
                                        Cursor="Hand" ToolTip="Explorer">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="5"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Btn.BackgroundHover}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="EXPLORER" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>

                                <!-- Search tab button -->
                                <Button x:Name="SidebarTabSearch"
                                        Click="SidebarTabSearch_Click"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource Editor.LineNumbers}"
                                        FontWeight="Normal" FontSize="11"
                                        FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                                        Padding="6,4" Margin="0,0,4,0"
                                        Cursor="Hand" ToolTip="Search in files">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="5"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Btn.BackgroundHover}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Search24" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="SEARCH" VerticalAlignment="Center" FontSize="11"/>
                                    </StackPanel>
                                </Button>

                                <!-- Bookmarks tab button -->
                                <Button x:Name="SidebarTabBookmarks"
                                        Click="SidebarTabBookmarks_Click"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource Editor.LineNumbers}"
                                        FontWeight="Normal" FontSize="11"
                                        FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                                        Padding="6,4"
                                        Cursor="Hand" ToolTip="Bookmarks">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="5"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Btn.BackgroundHover}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Bookmark24" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="BOOKMARKS" VerticalAlignment="Center" FontSize="11"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Content area: Explorer tree / Search panel -->
                    <Grid>
                        <!-- Explorer Content -->
                        <TreeView x:Name="ExplorerTree"
                                  Background="Transparent"
                                  Foreground="{DynamicResource App.Foreground}"
                                  BorderThickness="0"
                                  MouseDoubleClick="ExplorerTree_MouseDoubleClick">
                            <TreeView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="New File..." Click="Explorer_NewFile_Click">
                                        <MenuItem.Icon><ui:SymbolIcon Symbol="DocumentAdd24"/></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="New Folder..." Click="Explorer_NewFolder_Click">
                                        <MenuItem.Icon><ui:SymbolIcon Symbol="FolderAdd24"/></MenuItem.Icon>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="Rename..." Click="Explorer_Rename_Click">
                                        <MenuItem.Icon><ui:SymbolIcon Symbol="Rename24"/></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Delete" Click="Explorer_Delete_Click">
                                        <MenuItem.Icon><ui:SymbolIcon Symbol="Delete24"/></MenuItem.Icon>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="Reveal in Explorer" Click="Explorer_Reveal_Click">
                                        <MenuItem.Icon><ui:SymbolIcon Symbol="FolderOpen24"/></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Open in Terminal" Click="Explorer_OpenTerminal_Click">
                                        <MenuItem.Icon><ui:SymbolIcon Symbol="Prompt24"/></MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </TreeView.ContextMenu>
                            <TreeView.Resources>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource App.Foreground}"/>
                                    <EventSetter Event="PreviewMouseRightButtonDown" Handler="TreeViewItem_PreviewMouseRightButtonDown"/>
                                </Style>
                            </TreeView.Resources>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate DataType="{x:Type services:WorkspaceNode}" ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <ui:SymbolIcon x:Name="NodeIcon" Symbol="Document24"
                                                       FontSize="14" Margin="0,0,6,0"
                                                       Foreground="{DynamicResource Editor.LineNumbers}"/>
                                        <TextBlock Text="{Binding Name}"
                                                   FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                                                   FontSize="13"/>
                                    </StackPanel>
                                    <HierarchicalDataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                            <Setter TargetName="NodeIcon" Property="Symbol" Value="Folder24"/>
                                            <Setter TargetName="NodeIcon" Property="Foreground" Value="{DynamicResource App.Accent}"/>
                                        </DataTrigger>
                                    </HierarchicalDataTemplate.Triggers>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>

                        <!-- Search Content -->
                        <Grid x:Name="SearchPanel" Visibility="Collapsed" Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Search query -->
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="SearchTermBox" Grid.Column="0"
                                         Padding="6,4" VerticalContentAlignment="Center"
                                         KeyDown="SearchTermBox_KeyDown"
                                         FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <Button x:Name="SearchBtn" Grid.Column="1"
                                        Padding="8,4" Margin="6,0,0,0"
                                        Click="SearchBtn_Click" Cursor="Hand"
                                        ToolTip="Start Search (Enter)">
                                    <ui:SymbolIcon Symbol="Search24" FontSize="14"/>
                                </Button>
                            </Grid>

                            <!-- Search options -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                                <ToggleButton x:Name="SearchMatchCaseToggle" Content="Aa"
                                              Width="30" Height="24" Padding="0" Margin="0,0,4,0"
                                              ToolTip="Match Case" Cursor="Hand"
                                              Style="{StaticResource SearchToggleStyle}"/>
                                <ToggleButton x:Name="SearchWholeWordToggle" Content="ab"
                                              Width="30" Height="24" Padding="0" Margin="0,0,4,0"
                                              ToolTip="Match Whole Word" Cursor="Hand"
                                              Style="{StaticResource SearchToggleStyle}"/>
                                <ToggleButton x:Name="SearchRegexToggle" Content=".*"
                                              Width="30" Height="24" Padding="0"
                                              ToolTip="Use Regular Expression" Cursor="Hand"
                                              Style="{StaticResource SearchToggleStyle}"/>
                            </StackPanel>

                            <!-- Status -->
                            <Grid Grid.Row="2" Margin="0,0,0,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="SearchStatusText" Grid.Row="0"
                                           Text="Ready to search"
                                           Foreground="{DynamicResource Editor.LineNumbers}"
                                           FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4"
                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                <ProgressBar x:Name="SearchProgress" Grid.Row="1"
                                             Height="2" IsIndeterminate="True"
                                             Visibility="Collapsed"/>
                            </Grid>

                            <!-- Results -->
                            <TreeView x:Name="SearchResultsTree" Grid.Row="3"
                                      Background="Transparent"
                                      Foreground="{DynamicResource App.Foreground}"
                                      BorderThickness="0"
                                      MouseDoubleClick="SearchResultsTree_MouseDoubleClick">
                                <TreeView.Resources>
                                    <HierarchicalDataTemplate DataType="{x:Type local:SearchResultFileNode}"
                                                              ItemsSource="{Binding Matches}">
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <ui:SymbolIcon Symbol="Document24" FontSize="13"
                                                           Margin="0,0,6,0"
                                                           Foreground="{DynamicResource Editor.LineNumbers}"/>
                                            <TextBlock Text="{Binding DisplayText}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                                                       FontSize="13"/>
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                    <DataTemplate DataType="{x:Type local:SearchResultMatchNode}">
                                        <StackPanel Orientation="Horizontal" Margin="0,1">
                                            <TextBlock Text="{Binding LineNumber, StringFormat='{}{0}:'}"
                                                       Foreground="{DynamicResource Editor.LineNumbers}"
                                                       Margin="0,0,6,0" FontSize="12"/>
                                            <TextBlock ctrl:SearchHighlightBehavior.HighlightableText="{Binding LineText}"
                                                       ctrl:SearchHighlightBehavior.SearchText="{Binding SearchTerm}"
                                                       ctrl:SearchHighlightBehavior.MatchCase="{Binding MatchCase}"
                                                       ctrl:SearchHighlightBehavior.WholeWord="{Binding WholeWord}"
                                                       ctrl:SearchHighlightBehavior.UseRegex="{Binding UseRegex}"
                                                       FontFamily="Consolas" FontSize="11"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </TreeView.Resources>
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="True"/>
                                        <Setter Property="Foreground" Value="{DynamicResource App.Foreground}"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                            </TreeView>
                        </Grid>

                        <!-- Bookmarks Content -->
                        <Grid x:Name="BookmarksPanel" Visibility="Collapsed" Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Bookmarks" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"
                                       Foreground="{DynamicResource App.Foreground}"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                            <ListView x:Name="BookmarksList" Grid.Row="1"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Foreground="{DynamicResource App.Foreground}"
                                      MouseDoubleClick="BookmarksList_MouseDoubleClick"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4" Width="auto">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Bookmark24" FontSize="12" Margin="0,0,6,0" Foreground="{DynamicResource App.Accent}"/>
                                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource App.Foreground}"
                                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                                <TextBlock Text="{Binding LineNumber, StringFormat=':L{0}'}" FontSize="12" Foreground="{DynamicResource Editor.LineNumbers}" Margin="4,0,0,0"
                                                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                            </StackPanel>
                                            <TextBlock Grid.Row="1" Text="{Binding PreviewText}" Margin="18,2,0,0" FontSize="11" 
                                                       Foreground="{DynamicResource Editor.LineNumbers}" TextTrimming="CharacterEllipsis"
                                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Grid>
                </DockPanel>
            </Grid>

            <!-- Sidebar splitter (1px Fluent line instead of 5px bar) -->
            <Border x:Name="SidebarSplitter"
                    Grid.Column="1"
                    Width="1"
                    Background="{DynamicResource App.Border}"
                    Cursor="SizeWE"
                    Visibility="Collapsed"
                    MouseLeftButtonDown="SidebarSplitter_MouseLeftButtonDown"/>

            <!-- Main area: TabControl + Terminal -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition x:Name="TerminalRow" Height="0"/>
                </Grid.RowDefinitions>

                <TabControl x:Name="Tabs"
                            Grid.Row="0"
                            Background="{DynamicResource App.Background}"
                            BorderBrush="{DynamicResource App.Border}"
                            BorderThickness="0,1,0,0"
                            SelectionChanged="Tabs_SelectionChanged"/>

                <GridSplitter x:Name="TerminalSplitter"
                              Grid.Row="1"
                              Height="5"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="{DynamicResource App.Border}"
                              ResizeBehavior="PreviousAndNext"
                              ResizeDirection="Rows"
                              Visibility="Collapsed"/>

                <ctrl:TerminalControl x:Name="Terminal"
                                      Grid.Row="2"
                                      Visibility="Collapsed"/>
            </Grid>
        </Grid>

    </DockPanel>
</ui:FluentWindow>
