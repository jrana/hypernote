<Application x:Class="HyperNote.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- WPF-UI Fluent Design brush tokens (swapped at runtime for Light/Dark) -->
                <!-- Note: ControlsDictionary is intentionally omitted — SymbolIcon and FluentWindow -->
                <!-- render via Generic.xaml built into the Wpf.Ui assembly. Loading ControlsDictionary -->
                <!-- would conflict with our custom Button/TextBox/MenuItem/ComboBox styles. -->
                <ui:ThemesDictionary Theme="Light"/>
                <ui:ControlsDictionary/>
                <!-- App-specific overrides: editor colors, syntax brushes, menu templates, etc.
                     Swapped at runtime by ThemeManager between Themes/Dark.xaml and Themes/Light.xaml -->
                <ResourceDictionary Source="Themes/Light.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
