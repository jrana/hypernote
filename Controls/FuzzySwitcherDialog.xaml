<Window x:Class="HyperNote.Controls.FuzzySwitcherDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Go to File"
        Width="550" Height="320"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated">
        
    <Border CornerRadius="8"
            Background="{DynamicResource App.Background}"
            BorderBrush="{DynamicResource App.Border}"
            BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="270" Color="#000" Opacity="0.45"/>
        </Border.Effect>
        
        <DockPanel Margin="12">
            <!-- Search bar -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="🔍" VerticalAlignment="Center" Margin="4,0,8,0" FontSize="14"/>
                <TextBox x:Name="SearchBox"
                         Grid.Column="1"
                         Background="Transparent"
                         Foreground="{DynamicResource App.Foreground}"
                         BorderThickness="0,0,0,1"
                         BorderBrush="{DynamicResource App.Border}"
                         CaretBrush="{DynamicResource App.Foreground}"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         Padding="2,4"
                         TextChanged="SearchBox_TextChanged"
                         PreviewKeyDown="SearchBox_PreviewKeyDown"/>
            </Grid>
            
            <!-- Matching Files List -->
            <ListBox x:Name="FileResults"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     MouseDoubleClick="FileResults_MouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="2,4">
                            <!-- Filename -->
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource App.Accent}"
                                       FontSize="12"/>
                            <!-- Relative Path -->
                            <TextBlock Text="{Binding RelativePath}"
                                       Foreground="{DynamicResource Editor.LineNumbers}"
                                       FontSize="10"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource App.Border}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource App.Accent}"/>
                                <Setter Property="Foreground" Value="{DynamicResource App.Background}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </DockPanel>
    </Border>
</Window>
