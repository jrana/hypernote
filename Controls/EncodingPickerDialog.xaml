<Window x:Class="HyperNote.Controls.EncodingPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select File Encoding"
        Width="450" Height="360"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated">
        
    <Border CornerRadius="8"
            Background="{DynamicResource App.Background}"
            BorderBrush="{DynamicResource App.Border}"
            BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="270" Color="#000" Opacity="0.45"/>
        </Border.Effect>
        
        <DockPanel Margin="12">
            <!-- Search bar -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="Encoding:" VerticalAlignment="Center" Margin="8,0,12,0" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource App.Accent}"/>
                <TextBox x:Name="SearchBox"
                          Grid.Column="1"
                          Background="Transparent"
                          Foreground="{DynamicResource App.Foreground}"
                          BorderThickness="0,0,0,1"
                          BorderBrush="{DynamicResource App.Border}"
                          CaretBrush="{DynamicResource App.Foreground}"
                          FontSize="14"
                          VerticalContentAlignment="Center"
                          Padding="2,4"
                          TextChanged="SearchBox_TextChanged"
                          PreviewKeyDown="SearchBox_PreviewKeyDown"/>
            </Grid>
            
            <!-- Bottom Buttons -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="ReopenBtn" Content="Reopen with Encoding" Click="ReopenBtn_Click"
                        Padding="12,6" Margin="0,0,8,0" IsDefault="True"/>
                <Button x:Name="SaveBtn" Content="Save with Encoding" Click="SaveBtn_Click"
                        Padding="12,6" Margin="0,0,8,0"/>
                <Button x:Name="CancelBtn" Content="Cancel" Click="CancelBtn_Click"
                        Padding="12,6" IsCancel="True"/>
            </StackPanel>
            
            <!-- Encodings List -->
            <ListBox x:Name="EncodingResults"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     MouseDoubleClick="EncodingResults_MouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2,4">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource App.Foreground}"
                                       FontSize="12"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource App.Border}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource App.Accent}"/>
                                <Setter Property="Foreground" Value="{DynamicResource App.Background}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </DockPanel>
    </Border>
</Window>
