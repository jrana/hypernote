<Window x:Class="HyperNote.Controls.FindReplaceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find" SizeToContent="WidthAndHeight"
        WindowStyle="ToolWindow" ResizeMode="NoResize" ShowInTaskbar="False"
        Background="{DynamicResource App.ChromeBackground}"
        Foreground="{DynamicResource App.Foreground}"
        WindowStartupLocation="CenterOwner">

    <Window.InputBindings>
        <KeyBinding Key="Esc" Command="Close"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="Close" Executed="Close_Executed"/>
    </Window.CommandBindings>

    <Grid Margin="12" Width="430">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- find row -->
            <RowDefinition Height="Auto"/>   <!-- replace row -->
            <RowDefinition Height="Auto"/>   <!-- options + buttons -->
            <RowDefinition Height="Auto"/>   <!-- status -->
        </Grid.RowDefinitions>

        <!-- Find row -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Find what:" VerticalAlignment="Center" Margin="0,0,8,6"/>
        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="FindBox" Margin="0,0,8,6"
                   VerticalContentAlignment="Center" Padding="3" KeyDown="FindBox_KeyDown"/>
        <Button    Grid.Row="0" Grid.Column="2" x:Name="FindNextButton" Content="Find Next"
                   MinWidth="96" Margin="0,0,0,6" Padding="6,3" Click="FindNext_Click" IsDefault="True"/>

        <!-- Replace row (hidden in Find-only mode) -->
        <TextBlock Grid.Row="1" Grid.Column="0" x:Name="ReplaceLabel" Text="Replace with:"
                   VerticalAlignment="Center" Margin="0,0,8,6"/>
        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="ReplaceBox" Margin="0,0,8,6"
                   VerticalContentAlignment="Center" Padding="3"/>
        <Button    Grid.Row="1" Grid.Column="2" x:Name="ReplaceButton" Content="Replace"
                   MinWidth="96" Margin="0,0,0,6" Padding="6,3" Click="Replace_Click"/>

        <!-- Options + remaining buttons -->
        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Top">
                <CheckBox x:Name="MatchCaseBox"  Content="Match case" Margin="0,2"/>
                <CheckBox x:Name="WholeWordBox"  Content="Match whole word only" Margin="0,2"/>
                <CheckBox x:Name="RegexBox"      Content="Regular expression" Margin="0,2"/>
            </StackPanel>

            <GroupBox Grid.Column="1" Header="Direction" Margin="8,0,12,0" Padding="8,2">
                <StackPanel>
                    <RadioButton x:Name="DownRadio" Content="Down (forward)" IsChecked="True" Margin="0,2"/>
                    <RadioButton x:Name="UpRadio"   Content="Up (backward)" Margin="0,2"/>
                </StackPanel>
            </GroupBox>

            <StackPanel Grid.Column="2" VerticalAlignment="Top">
                <Button x:Name="ReplaceAllButton" Content="Replace All" MinWidth="96"
                        Margin="0,2" Padding="6,3" Click="ReplaceAll_Click"/>
                <Button x:Name="CountButton" Content="Count" MinWidth="96"
                        Margin="0,2" Padding="6,3" Click="Count_Click"/>
                <Button Content="Close" MinWidth="96" Margin="0,2" Padding="6,3"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- Status -->
        <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" x:Name="StatusLabel"
                   Margin="0,8,0,0" TextWrapping="Wrap" Foreground="{DynamicResource App.Accent}"/>
    </Grid>
</Window>
