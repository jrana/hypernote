<Window x:Class="HyperNote.Controls.SessionPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Sessions"
        Height="300" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource App.ChromeBackground}"
        Foreground="{DynamicResource App.Foreground}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock x:Name="TxtHeader" Grid.Row="0" Text="Select a Session" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

        <!-- Session List -->
        <ListBox x:Name="LstSessions" Grid.Row="1" Background="{DynamicResource App.Background}" Foreground="{DynamicResource App.Foreground}" BorderBrush="{DynamicResource App.Border}" BorderThickness="1" SelectionMode="Single" Margin="0,0,0,12" MouseDoubleClick="LstSessions_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" Padding="6,4" FontSize="12"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnAction" Content="Select" Width="90" Margin="4,0" Padding="8,4" Click="BtnAction_Click" IsDefault="True"/>
            <Button x:Name="BtnCancel" Content="Cancel" Width="80" Margin="4,0" Padding="8,4" Click="BtnCancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
