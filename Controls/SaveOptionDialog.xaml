<Window x:Class="HyperNote.Controls.SaveOptionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save Changes"
        Height="190" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource App.ChromeBackground}"
        Foreground="{DynamicResource App.Foreground}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Message -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center">
            <TextBlock Text="Save Changes" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
            <TextBlock x:Name="TxtMessage" Text="How would you like to save changes?" TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource App.Foreground}"/>
        </StackPanel>

        <!-- Actions -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="BtnOverwrite" Content="Overwrite" Width="90" Margin="4,0" Padding="8,4" Click="BtnOverwrite_Click" IsDefault="True"/>
            <Button x:Name="BtnSaveCopy" Content="Save a Copy" Width="95" Margin="4,0" Padding="8,4" Click="BtnSaveCopy_Click"/>
            <Button x:Name="BtnCancel" Content="Cancel" Width="80" Margin="4,0" Padding="8,4" Click="BtnCancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
