<Window x:Class="HyperNote.Controls.GoToLineDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Go to Line"
        Width="350" Height="100"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated">
        
    <Border CornerRadius="8"
            Background="{DynamicResource App.Background}"
            BorderBrush="{DynamicResource App.Border}"
            BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="270" Color="#000" Opacity="0.45"/>
        </Border.Effect>
        
        <StackPanel Margin="16,12">
            <TextBlock x:Name="PromptText" Text="Go to line (1-100):" Foreground="{DynamicResource App.Foreground}" FontSize="12" Margin="0,0,0,6"/>
            <TextBox x:Name="LineBox"
                     Background="Transparent"
                     Foreground="{DynamicResource App.Foreground}"
                     BorderThickness="0,0,0,1"
                     BorderBrush="{DynamicResource App.Border}"
                     CaretBrush="{DynamicResource App.Foreground}"
                     FontSize="14"
                     VerticalContentAlignment="Center"
                     Padding="2,4"
                     KeyDown="LineBox_KeyDown"/>
        </StackPanel>
    </Border>
</Window>
