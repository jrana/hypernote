<Window x:Class="HyperNote.Controls.HashCalculatorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Compute Hash — HyperNote"
        Width="550" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource App.Background}"
        Foreground="{DynamicResource App.Foreground}">

    <Window.Resources>
        <!-- Style for copy buttons -->
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.Border}"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Foreground}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource App.Border}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style for dialog text boxes -->
        <Style x:Key="HashTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Foreground}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource App.Border}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource App.Foreground}"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="2,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Source selection -->
            <RowDefinition Height="Auto"/> <!-- Browse section -->
            <RowDefinition Height="*"/>    <!-- Hashes display grid -->
            <RowDefinition Height="Auto"/> <!-- Footer controls -->
        </Grid.RowDefinitions>

        <!-- 1. Source Selection -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Source:" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="SemiBold"/>
            <ComboBox x:Name="SourceCombo" Grid.Column="1" SelectionChanged="SourceCombo_SelectionChanged" Height="28">
                <ComboBoxItem Content="Active Tab (Entire Document)" Tag="TabEntire"/>
                <ComboBoxItem x:Name="SelectedTextComboItem" Content="Selected Text" Tag="TabSelection"/>
                <ComboBoxItem Content="External File on Disk..." Tag="ExternalFile"/>
            </ComboBox>
        </Grid>

        <!-- 2. Browse Section (only visible when External File is selected) -->
        <Grid x:Name="BrowseGrid" Grid.Row="1" Margin="0,0,0,12" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="FilePathBox" Style="{StaticResource HashTextBoxStyle}" IsReadOnly="True" Margin="0,0,8,0" VerticalAlignment="Center" FontFamily="Segoe UI"/>
            <Button Grid.Column="1" Content="Browse..." Click="Browse_Click" Style="{StaticResource DialogButtonStyle}" Height="28"/>
        </Grid>

        <!-- 3. Hashes Display Grid -->
        <Grid Grid.Row="2" Margin="0,8,0,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- MD5 -->
            <TextBlock Grid.Row="0" Text="MD5" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBox x:Name="Md5Box" Grid.Row="0" Grid.Column="1" Style="{StaticResource HashTextBoxStyle}" Margin="0,0,8,6" GotFocus="TextBox_GotFocus"/>
            <Button Grid.Row="0" Grid.Column="2" Content="Copy" Click="CopyMd5_Click" Style="{StaticResource DialogButtonStyle}" Margin="0,0,0,6"/>

            <!-- SHA-1 -->
            <TextBlock Grid.Row="1" Text="SHA-1" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBox x:Name="Sha1Box" Grid.Row="1" Grid.Column="1" Style="{StaticResource HashTextBoxStyle}" Margin="0,0,8,6" GotFocus="TextBox_GotFocus"/>
            <Button Grid.Row="1" Grid.Column="2" Content="Copy" Click="CopySha1_Click" Style="{StaticResource DialogButtonStyle}" Margin="0,0,0,6"/>

            <!-- SHA-256 -->
            <TextBlock Grid.Row="2" Text="SHA-256" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBox x:Name="Sha256Box" Grid.Row="2" Grid.Column="1" Style="{StaticResource HashTextBoxStyle}" Margin="0,0,8,6" GotFocus="TextBox_GotFocus"/>
            <Button Grid.Row="2" Grid.Column="2" Content="Copy" Click="CopySha256_Click" Style="{StaticResource DialogButtonStyle}" Margin="0,0,0,6"/>

            <!-- SHA-512 -->
            <TextBlock Grid.Row="3" Text="SHA-512" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBox x:Name="Sha512Box" Grid.Row="3" Grid.Column="1" Style="{StaticResource HashTextBoxStyle}" Margin="0,0,8,0" GotFocus="TextBox_GotFocus"/>
            <Button Grid.Row="3" Grid.Column="2" Content="Copy" Click="CopySha512_Click" Style="{StaticResource DialogButtonStyle}"/>
        </Grid>

        <!-- 4. Footer controls -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <CheckBox x:Name="UppercaseCheck" Content="Uppercase Hex" IsChecked="True" Checked="CaseCheck_Changed" Unchecked="CaseCheck_Changed" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Copy All" Click="CopyAll_Click" Style="{StaticResource DialogButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="Close" Click="Close_Click" Style="{StaticResource DialogButtonStyle}" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
