<UserControl x:Class="HyperNote.Controls.TerminalControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource App.Background}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Command history output -->
        <TextBox x:Name="TerminalOutput"
                 Grid.Row="0"
                 Background="{DynamicResource App.Background}"
                 Foreground="{DynamicResource App.Foreground}"
                 BorderThickness="0"
                 FontFamily="Consolas"
                 FontSize="12"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Padding="8"/>

        <!-- Command input line -->
        <Grid Grid.Row="1" Background="{DynamicResource App.ChromeBackground}" Height="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Text="PS > "
                       Grid.Column="0"
                       Foreground="{DynamicResource App.Accent}"
                       FontFamily="Consolas"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="8,0,2,0"/>
                       
            <TextBox x:Name="TerminalInput"
                     Grid.Column="1"
                     Background="Transparent"
                     Foreground="{DynamicResource App.Foreground}"
                     BorderThickness="0"
                     CaretBrush="{DynamicResource App.Foreground}"
                     FontFamily="Consolas"
                     FontSize="12"
                     VerticalContentAlignment="Center"
                     Padding="2,0,8,0"
                     KeyDown="TerminalInput_KeyDown"/>
        </Grid>
    </Grid>
</UserControl>
