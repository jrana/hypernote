<UserControl x:Class="HyperNote.Controls.TerminalControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="{DynamicResource App.Background}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Terminal Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource App.ChromeBackground}"
                BorderBrush="{DynamicResource App.Border}"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <DockPanel LastChildFill="True">
                <!-- Action Buttons on the right -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Push Output to New Note -->
                    <Button x:Name="PushOutputBtn"
                            Click="PushOutputBtn_Click"
                            Width="26" Height="26" Padding="0" Margin="0,0,4,0"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource App.Foreground}"
                            Cursor="Hand" ToolTip="Push Terminal Output to New Note">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Btn.BackgroundHover}"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Btn.BackgroundPress}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <ui:SymbolIcon Symbol="DocumentAdd24" FontSize="14"/>
                    </Button>

                    <!-- Close Button -->
                    <Button x:Name="CloseBtn"
                            Click="CloseBtn_Click"
                            Width="26" Height="26" Padding="0" Margin="0"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource App.Foreground}"
                            Cursor="Hand" ToolTip="Close Terminal">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Btn.BackgroundHover}"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Btn.BackgroundPress}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <ui:SymbolIcon Symbol="Dismiss24" FontSize="12"/>
                    </Button>
                </StackPanel>

                <!-- Title on the left -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Terminal24" FontSize="14" Foreground="{DynamicResource App.Accent}" Margin="0,0,6,0"/>
                    <TextBlock Text="TERMINAL"
                               Foreground="{DynamicResource App.Foreground}"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                               FontSize="11"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Command history output -->
        <TextBox x:Name="TerminalOutput"
                 Grid.Row="1"
                 Background="{DynamicResource App.Background}"
                 Foreground="{DynamicResource App.Foreground}"
                 BorderThickness="0"
                 FontFamily="Consolas"
                 FontSize="12"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Padding="8"/>

        <!-- Command input line -->
        <Grid Grid.Row="2" Background="{DynamicResource App.ChromeBackground}" Height="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Text="PS > "
                       Grid.Column="0"
                       Foreground="{DynamicResource App.Accent}"
                       FontFamily="Consolas"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="8,0,2,0"/>
                       
            <TextBox x:Name="TerminalInput"
                     Grid.Column="1"
                     Background="Transparent"
                     Foreground="{DynamicResource App.Foreground}"
                     BorderThickness="0"
                     CaretBrush="{DynamicResource App.Foreground}"
                     FontFamily="Consolas"
                     FontSize="12"
                     VerticalContentAlignment="Center"
                     Padding="2,0,8,0"
                     KeyDown="TerminalInput_KeyDown"/>
        </Grid>
    </Grid>
</UserControl>
