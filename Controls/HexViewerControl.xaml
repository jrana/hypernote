<UserControl x:Class="HyperNote.Controls.HexViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="{DynamicResource App.Background}">
    <DockPanel>
        <!-- Hex Viewer Toolbar -->
        <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource App.Border}" Padding="8,4" Background="{DynamicResource App.ChromeBackground}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <TextBlock Text="Bytes per row:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12" Foreground="{DynamicResource App.Foreground}"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <ComboBox x:Name="BytesPerRowCombo" Width="80" SelectedIndex="1" SelectionChanged="BytesPerRowCombo_SelectionChanged">
                        <ComboBoxItem Content="8"/>
                        <ComboBoxItem Content="16"/>
                        <ComboBoxItem Content="32"/>
                    </ComboBox>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Grid.Column="2">
                    <ui:TextBox x:Name="SearchBox" Width="180" PlaceholderText="Search Hex or Text..." KeyDown="SearchBox_KeyDown" Margin="0,0,6,0"
                             FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                    <Button Content="Find" Click="FindButton_Click" FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Virtualized ListView -->
        <ListView x:Name="HexList"
                  Background="Transparent"
                  BorderThickness="0"
                  FontFamily="Consolas"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  Grid.IsSharedSizeScope="True">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="Offset"/>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="Spacer1"/>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="Hex"/>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="Spacer2"/>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="Ascii"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="{Binding OffsetHex}" Foreground="{DynamicResource Editor.LineNumbers}" Margin="0,0,16,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding BytesHex}" Foreground="{DynamicResource App.Foreground}" Margin="0,0,24,0" MouseDown="HexText_MouseDown"/>
                        <TextBlock Grid.Column="4" Text="{Binding Ascii}" Foreground="{DynamicResource App.Accent}" MouseDown="AsciiText_MouseDown"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="4,1"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource App.Border}"/>
                            <Setter Property="Foreground" Value="{DynamicResource App.Foreground}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </DockPanel>
</UserControl>
